# --- ASR backend (OpenAI-compatible) ---
# Provider selects the upstream API style:
#   openai_compat      → POST /v1/audio/transcriptions  (Whisper-style, multipart)
#                        Use for Whisper API, faster-whisper-server, DashScope compat
#                        transcriptions endpoint, Paraformer/SenseVoice OpenAI shims
#   openai_chat_audio  → POST /v1/chat/completions      (multimodal chat, JSON)
#                        Use for vLLM Qwen3-ASR-Flash, DashScope compat chat endpoint,
#                        any multimodal LLM serving as ASR. No word timestamps.
ASR_PROVIDER=openai_compat
ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_API_KEY=
ASR_MODEL=qwen3-asr-flash
ASR_LANGUAGE=zh
ASR_TIMEOUT=120
ASR_TIMESTAMPS=true               # request verbose_json + word/segment timestamps
                                  # if your upstream (some vLLM builds) rejects this, set to false

# Optional biasing — leave empty to disable.
# ASR_HOTWORDS: comma-separated jargon/names to bias toward (e.g. "千问,ASR,声学模型")
# ASR_PROMPT_HINTS: free-form context sent verbatim as the OpenAI `prompt` field
ASR_HOTWORDS=
ASR_PROMPT_HINTS=

# --- Audio splitting ---
SPLIT_STRATEGY=silence            # fixed | silence | overlap
SPLIT_CHUNK_SECONDS=30
SPLIT_OVERLAP_SECONDS=2
SILENCE_NOISE_DB=-30
SILENCE_MIN_DURATION=0.4

# --- Concurrency & retry ---
ASR_CONCURRENCY=4
ASR_MAX_RETRIES=3
ASR_RETRY_BACKOFF=1.5

# --- FFmpeg execution ---
FFMPEG_TIMEOUT=1800               # per-process wall-clock cap (s); guards a hung/corrupt input
FFMPEG_CONCURRENCY=4              # max concurrent ffmpeg slice processes (caps fork fan-out)

# --- Limits ---
MAX_UPLOAD_BYTES=2147483648       # 2 GiB
MAX_TASKS_IN_MEMORY=100
TASK_TTL_SECONDS=3600

# --- Auth (optional) ---
# Comma-separated tokens. Leave empty to disable auth.
# Clients pass `Authorization: Bearer <token>` (or `?token=<token>` for SSE).
ACCESS_TOKENS=

# --- Realtime ---
# realtime_mock      → synthetic provider for pipeline testing (no real ASR)
# realtime_http      → standard downstream service speaking POST /session,
#                      POST /session/{id}/audio (JSON base64), GET /events (SSE),
#                      POST /session/{id}/end. Wrap non-standard backends (e.g.
#                      FunASR WebSocket) in a thin shim that exposes this surface.
REALTIME_ASR_PROVIDER=realtime_mock
REALTIME_ASR_BASE_URL=
REALTIME_ASR_API_KEY=
REALTIME_ASR_MODEL=
REALTIME_MAX_SESSIONS=100
REALTIME_SESSION_TTL_SECONDS=300
REALTIME_MAX_CHUNK_BYTES=1048576    # 1 MiB per chunk

# --- Storage ---
TEMP_DIR=./temp
OUTPUT_DIR=./outputs

# --- Server ---
HOST=0.0.0.0
PORT=8999
LOG_LEVEL=info
